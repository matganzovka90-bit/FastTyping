<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="speed.fasttyping.controller.StatsController"
      style="-fx-background-color: #2b2b2b;"
      maxWidth="Infinity" maxHeight="Infinity">

    <padding>
        <Insets top="20" right="40" bottom="40" left="40"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Назад"
                onAction="#handleBackClick"
                style="-fx-background-color: transparent; -fx-text-fill: #a9b7c6;
                       -fx-cursor: hand; -fx-font-size: 14px; -fx-underline: true;"/>
        <Label text="Статистика"
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="20" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #3c3f41; -fx-background-radius: 10; -fx-padding: 20 40 20 40;">
            <Label text="КРАЩИЙ WPM"
                   style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label fx:id="bestWpmLabel" text="0"
                   style="-fx-text-fill: #4b6eaf; -fx-font-size: 36px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #3c3f41; -fx-background-radius: 10; -fx-padding: 20 40 20 40;">
            <Label text="СЕРЕДНЯ ТОЧНІСТЬ"
                   style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label fx:id="avgAccuracyLabel" text="0%"
                   style="-fx-text-fill: #629755; -fx-font-size: 36px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #3c3f41; -fx-background-radius: 10; -fx-padding: 20 40 20 40;">
            <Label text="ВСЬОГО СЕСІЙ"
                   style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label fx:id="totalSessionsLabel" text="0"
                   style="-fx-text-fill: #a9b7c6; -fx-font-size: 36px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <VBox spacing="20" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/17"
          xmlns:fx="http://javafx.com/fxml/1"
          style="-fx-background-color: #2b2b2b;"
          stylesheets="@style.css"> <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS" maxWidth="Infinity">
        <columns>
            <TableColumn fx:id="wpmColumn" text="WPM" prefWidth="100"/>
            <TableColumn fx:id="accuracyColumn" text="ТОЧНІСТЬ" prefWidth="120"/>
            <TableColumn fx:id="errorsColumn" text="ПОМИЛКИ" prefWidth="100"/>
            <TableColumn fx:id="modeColumn" text="РЕЖИМ" prefWidth="150"/>
            <TableColumn fx:id="dateColumn" text="ДАТА" prefWidth="180"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
    </VBox>
</VBox>