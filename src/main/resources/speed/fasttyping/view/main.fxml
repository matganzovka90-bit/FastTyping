<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.text.TextFlow?>
<VBox spacing="20" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="speed.fasttyping.controller.MainWindowController"
      style="-fx-background-color: #2b2b2b;"
      maxWidth="Infinity" maxHeight="Infinity">

    <padding>
        <Insets top="20" right="40" bottom="40" left="40"/>
    </padding>

    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 0 0 20 0;">
        <Button text="Статистика"
                onAction="#handleStatsClick"
                style="-fx-background-color: transparent; -fx-text-fill: #4b6eaf; -fx-cursor: hand; -fx-font-size: 14px; -fx-underline: true;"/>

        <Label text="|" style="-fx-text-fill: #555555;"/>

        <Button fx:id="loginBtn"
                text="Увійти"
                onAction="#handleLoginButtonClick"
                style="-fx-background-color: transparent; -fx-text-fill: #a9b7c6; -fx-cursor: hand; -fx-font-size: 14px;"/>

        <Button fx:id="registerBtn"
                text="Реєстрація"
                onAction="#handleRegistrationButtonClick"
                style="-fx-background-color: #4b6eaf; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;"/>
    </HBox>

    <HBox alignment="CENTER" spacing="15">
        <Button text="Легкий"
                onAction="#handleEasyMode"
                style="-fx-background-color: #629755; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-cursor: hand; -fx-background-radius: 8;
                       -fx-pref-width: 140; -fx-pref-height: 38;"/>

        <Button text="Атака часу"
                onAction="#handleTimeAttackMode"
                style="-fx-background-color: #4b6eaf; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-cursor: hand; -fx-background-radius: 8;
                       -fx-pref-width: 140; -fx-pref-height: 38;"/>

        <Button text="Марафон"
                onAction="#handleMarathonMode"
                style="-fx-background-color: #8b4fab; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-cursor: hand; -fx-background-radius: 8;
                       -fx-pref-width: 140; -fx-pref-height: 38;"/>
    </HBox>

    <Label fx:id="modeLabel"
           style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>

    <Label fx:id="achievementPopup"
           text=""
           visible="false"
           managed="false"
           style="-fx-background-color: #1e3a1e;
              -fx-border-color: #629755;
              -fx-border-width: 2;
              -fx-border-radius: 12;
              -fx-background-radius: 12;
              -fx-text-fill: #c5e1a5;
              -fx-font-size: 16px;
              -fx-font-weight: bold;
              -fx-padding: 14 20 14 20;"/>

    <VBox spacing="30" alignment="CENTER" VBox.vgrow="ALWAYS">
        <StackPane style="-fx-background-color: #3c3f41; -fx-background-radius: 15; -fx-padding: 25;">
            <TextFlow fx:id="textFlow"
                      maxWidth="700"
                      prefWidth="700"
                      style="-fx-line-spacing: 10;"/>
        </StackPane>

        <TextField fx:id="userInputField"
                   promptText="Починайте друкувати..."
                   maxWidth="600"
                   style="-fx-background-color: transparent;
                          -fx-border-color: #4b6eaf;
                          -fx-border-width: 0 0 2 0;
                          -fx-text-fill: white;
                          -fx-font-size: 22px;
                          -fx-prompt-text-fill: #555555;
                          -fx-alignment: CENTER;"/>

        <HBox spacing="80" alignment="CENTER">
            <VBox alignment="CENTER">
                <Label text="ШВИДКІСТЬ" style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label fx:id="wpmLabel" text="0" style="-fx-font-size: 32px; -fx-text-fill: #4b6eaf; -fx-font-weight: bold;"/>
                <Label text="WPM" style="-fx-text-fill: #777777; -fx-font-size: 10px;"/>
            </VBox>

            <VBox alignment="CENTER">
                <Label text="ТОЧНІСТЬ" style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label fx:id="accuracyLabel" text="100%" style="-fx-text-fill: #629755; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                <Label text="ACCURACY" style="-fx-text-fill: #777777; -fx-font-size: 10px;"/>
            </VBox>

            <VBox alignment="CENTER">
                <Label text="ПОМИЛКИ" style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label fx:id="errorsLabel" text="0" style="-fx-text-fill: #cc3232; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                <Label text="ERRORS" style="-fx-text-fill: #777777; -fx-font-size: 10px;"/>
            </VBox>
        </HBox>
    </VBox>

</VBox>
