<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="speed.fasttyping.controller.AuthController"
           style="-fx-background-color: #2b2b2b;"
           maxWidth="Infinity" maxHeight="Infinity">

    <VBox alignment="CENTER" spacing="0" maxWidth="460">

        <HBox alignment="CENTER" spacing="0">
            <Button fx:id="loginTabBtn" text="Увійти"
                    onAction="#onLoginTabClick"
                    style="-fx-background-color: #3c3f41; -fx-text-fill: #4b6eaf;
                           -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-pref-width: 180; -fx-pref-height: 44;
                           -fx-background-radius: 10 10 0 0; -fx-border-color: transparent;"/>
            <Button fx:id="registerTabBtn" text="Реєстрація"
                    onAction="#onRegisterTabClick"
                    style="-fx-background-color: #2b2b2b; -fx-text-fill: #777777;
                           -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-pref-width: 180; -fx-pref-height: 44;
                           -fx-background-radius: 10 10 0 0; -fx-border-color: transparent;"/>
        </HBox>

        <VBox alignment="CENTER" spacing="20"
              style="-fx-background-color: #3c3f41; -fx-background-radius: 0 15 15 15;
                     -fx-padding: 40 50 40 50;">

            <VBox alignment="CENTER" spacing="6">
                <Label fx:id="titleLabel" text="Вітаємо назад"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #a9b7c6;"/>
                <Label fx:id="subtitleLabel" text="Увійдіть, щоб продовжити тренування"
                       style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            </VBox>

            <Label fx:id="errorLabel" text=""
                   wrapText="true" maxWidth="320"
                   style="-fx-text-fill: #e06c75; -fx-font-size: 13px; -fx-alignment: CENTER;"/>

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Ім'я користувача"
                       style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <TextField fx:id="usernameField" promptText="Введіть ім'я..."
                           maxWidth="Infinity"
                           style="-fx-background-color: #2b2b2b; -fx-text-fill: #a9b7c6;
                                  -fx-prompt-text-fill: #555555; -fx-border-color: #4b4b4b;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-font-size: 14px; -fx-pref-height: 42; -fx-padding: 0 12 0 12;"/>
            </VBox>

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Пароль"
                       style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField" promptText="Введіть пароль..."
                               maxWidth="Infinity"
                               style="-fx-background-color: #2b2b2b; -fx-text-fill: #a9b7c6;
                                      -fx-prompt-text-fill: #555555; -fx-border-color: #4b4b4b;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-font-size: 14px; -fx-pref-height: 42; -fx-padding: 0 12 0 12;"/>
            </VBox>

            <VBox fx:id="confirmBox" spacing="6" maxWidth="Infinity"
                  visible="false" managed="false">
                <Label text="Підтвердіть пароль"
                       style="-fx-text-fill: #777777; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Повторіть пароль..."
                               maxWidth="Infinity"
                               style="-fx-background-color: #2b2b2b; -fx-text-fill: #a9b7c6;
                                      -fx-prompt-text-fill: #555555; -fx-border-color: #4b4b4b;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-font-size: 14px; -fx-pref-height: 42; -fx-padding: 0 12 0 12;"/>
            </VBox>

            <Button fx:id="submitBtn" text="Увійти"
                    onAction="#onSubmitClick"
                    maxWidth="Infinity"
                    style="-fx-background-color: #4b6eaf; -fx-text-fill: white;
                           -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-pref-height: 46; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Button text="← Назад"
                    onAction="#onBackClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-cursor: hand; -fx-underline: true;"/>

        </VBox>
    </VBox>
</StackPane>
